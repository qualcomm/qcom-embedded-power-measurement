#include <windows.h>

@VI_ICON_LINE@

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @VI_FILE_VERSION_CSV@
 PRODUCTVERSION @VI_PRODUCT_VERSION_CSV@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE @VI_FILE_TYPE@
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Qualcomm Technologies, Inc."
            VALUE "FileDescription",  "@VI_FILE_DESCRIPTION@"
            VALUE "FileVersion",      "@VI_FILE_VERSION_STR@"
            VALUE "InternalName",     "@VI_INTERNAL_NAME@"
            VALUE "LegalCopyright",   "Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries."
            VALUE "OriginalFilename", "@VI_ORIGINAL_FILENAME@"
            VALUE "ProductName",      "Qualcomm Embedded Power Measurement"
            VALUE "ProductVersion",   "@VI_PRODUCT_VERSION_STR@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
